.venv/
.venv-*/
__pycache__/
*.pyc

# Local Ansible/runtime files
*.retry
.ansible/

# Real inventory, vars, and secrets
inventory/inventory.yml
inventory/group_vars/ndfc/vars.yml
inventory/group_vars/ndfc/vault.yml
